DB_URL=jdbc:postgresql://localhost:5432/azurion
DB_USER=postgres
DB_PASS=postgres
DB_POOL_MAX=30
DB_POOL_MIN=5
SERVER_PORT=8080
JWT_SECRET=replace_this_with_very_long_secure_secret_32_chars_minimum
JWT_ISSUER=azurion
JWT_EXP_MIN=120
FACTURADOR_BASE_URL=http://127.0.0.1:8000
FACTURADOR_API_PREFIX=/api
FACTURADOR_API_KEY=
FACTURADOR_CONNECT_TIMEOUT_MS=5000
FACTURADOR_READ_TIMEOUT_MS=20000
FACTURADOR_WAIT_PROCESSED_ENABLED=true
FACTURADOR_WAIT_PROCESSED_TIMEOUT_MS=90000
FACTURADOR_WAIT_PROCESSED_POLL_INTERVAL_MS=1500
FACTURADOR_CALLBACK_ENABLED=true
FACTURADOR_CALLBACK_API_KEY=
FACTURADOR_CALLBACK_SECRET=
FACTURADOR_CALLBACK_HEADER_API_KEY=X-API-Key
FACTURADOR_CALLBACK_HEADER_SIGNATURE=X-Signature
FACTURADOR_CALLBACK_HEADER_TIMESTAMP=X-Timestamp
FACTURADOR_CALLBACK_HEADER_NONCE=X-Nonce
FACTURADOR_CALLBACK_TOLERANCE_SECONDS=300
FACTURADOR_CALLBACK_NONCE_TTL_SECONDS=600
