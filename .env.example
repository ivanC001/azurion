DB_URL=jdbc:postgresql://localhost:5432/azurion
DB_USER=postgres
DB_PASS=postgres
DB_POOL_MAX=30
DB_POOL_MIN=5
SERVER_PORT=8080
# Obligatorio: genera una clave aleatoria distinta para cada entorno (minimo 32 bytes).
JWT_SECRET=
JWT_ISSUER=azurion
JWT_EXP_MIN=120
AZURION_EMAIL_SECRET_KEY=
AZURION_EMAIL_SECRET_KEY_PREVIOUS=
AZURION_CRM_SECRET_KEY=
AZURION_BOOTSTRAP_ADMIN_USERNAME=
AZURION_BOOTSTRAP_ADMIN_PASSWORD=
CORS_ALLOWED_ORIGINS=http://localhost:4200
RATE_LIMIT_ENABLED=true
RATE_LIMIT_AUTH_PER_MINUTE=10
RATE_LIMIT_PUBLIC_PER_MINUTE=60
RATE_LIMIT_MAX_CLIENTS=10000
# IPs exactas del reverse proxy que pueden aportar X-Forwarded-For.
RATE_LIMIT_TRUSTED_PROXIES=127.0.0.1,::1
SMTP_CONNECT_TIMEOUT_MS=10000
SMTP_READ_TIMEOUT_MS=20000
SMTP_WRITE_TIMEOUT_MS=20000
SMTP_TLS_PROTOCOLS=TLSv1.2 TLSv1.3
SMTP_CHECK_SERVER_IDENTITY=true
AZURION_PUBLIC_FILES_DIR=./storage/public-files
AZURION_PRIVATE_FILES_DIR=./storage/private-files
MULTIPART_MAX_FILE_SIZE=8MB
MULTIPART_MAX_REQUEST_SIZE=10MB
FACTURADOR_BASE_URL=http://127.0.0.1:8000
FACTURADOR_API_PREFIX=/api
FACTURADOR_API_KEY=
FACTURADOR_CONNECT_TIMEOUT_MS=5000
FACTURADOR_READ_TIMEOUT_MS=20000
# En produccion debe permanecer false: el outbox/callback actualiza SUNAT sin mantener HTTP abierto 90 s.
FACTURADOR_WAIT_PROCESSED_ENABLED=false
FACTURADOR_WAIT_PROCESSED_TIMEOUT_MS=90000
FACTURADOR_WAIT_PROCESSED_POLL_INTERVAL_MS=1500
FACTURADOR_CALLBACK_ENABLED=true
FACTURADOR_CALLBACK_API_KEY=
FACTURADOR_CALLBACK_SECRET=
FACTURADOR_CALLBACK_HEADER_API_KEY=X-API-Key
FACTURADOR_CALLBACK_HEADER_SIGNATURE=X-Signature
FACTURADOR_CALLBACK_HEADER_TIMESTAMP=X-Timestamp
FACTURADOR_CALLBACK_HEADER_NONCE=X-Nonce
FACTURADOR_CALLBACK_TOLERANCE_SECONDS=300
FACTURADOR_CALLBACK_NONCE_TTL_SECONDS=600
WHATSAPP_GRAPH_BASE_URL=https://graph.facebook.com
WHATSAPP_GRAPH_API_VERSION=v25.0
WHATSAPP_CONNECT_TIMEOUT_MS=5000
WHATSAPP_READ_TIMEOUT_MS=15000
FACTURADOR_OUTBOX_INITIAL_DELAY_MS=5000
FACTURADOR_OUTBOX_ENABLED=true
FACTURADOR_OUTBOX_POLL_DELAY_MS=2000
FACTURADOR_OUTBOX_CLEANUP_CRON=0 30 3 * * *
